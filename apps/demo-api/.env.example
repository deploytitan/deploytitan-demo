PORT=3001

# GitHub — personal access token with repo write access
GITHUB_TOKEN=ghp_your_token_here
GITHUB_OWNER=your-github-username
GITHUB_REPO=deploytitan-demo
GITHUB_BRANCH=main

# DeployTitan backend
DEPLOYTITAN_API_URL=https://api.deploytitan.com
DEPLOYTITAN_API_KEY=dt_your_api_key_here
SERVICE_NAME=demo-service
ENVIRONMENT=production

# Controller URL (internal Cloud Run URL)
CONTROLLER_URL=https://controller-xxx-uc.a.run.app

# CORS — set to your UI domain in production
CORS_ORIGIN=http://localhost:5173
